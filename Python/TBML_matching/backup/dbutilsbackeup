def insert_transaction_items(transaction_no, items, user_id):
    conn = get_db_connection()
    cursor = conn.cursor()

    for item in items:
        cursor.execute(
            "EXEC sp_insert_transaction_item ?,?,?,?,?,?",
            transaction_no,
            item["good_code"],
            item["description"],
            int(item["quantity"]),
            float(item["unit_price"]),
            user_id
        )

    conn.commit()
    conn.close()



