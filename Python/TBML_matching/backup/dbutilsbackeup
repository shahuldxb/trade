        )

        conn.commit()
        print(f"[DB] Successfully inserted ExportControlItem {data['control_code']}")

    except pyodbc.Error as e:
        print(f"[DB][ERROR] Failed to insert ExportControlItem: {e}")

    finally:
        conn.close()
        print("[DB] Connection closed")

