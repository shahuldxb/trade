def get_db_connection():
    """
    Get database connection
    
    Returns:
        pyodbc.Connection: Database connection object
    """
    try:
        server = os.getenv("DB_SERVER")
        database = os.getenv("DB_NAME")
        username = os.getenv("DB_USER")
        password = os.getenv("DB_PASSWORD")
        timeout = os.getenv("DB_TIMEOUT", "30")
        
        connection_string = (
            f"DRIVER={{ODBC Driver 17 for SQL Server}};"
            f"SERVER={server};"
            f"DATABASE={database};"
            f"UID={username};"
            f"PWD={password};"
            f"Timeout={timeout};"
        )
        
        conn = pyodbc.connect(connection_string)
        log_message("Database connection established", "SQL")
        return conn
        
    except Exception as e:
        log_message(f"Failed to establish database connection: {str(e)}", "ERROR")
        raise


def get_sanctions_data():
    """
    Retrieve all sanctions data from tf_sanctions table
    
    Returns:
        list: List of dictionaries containing sanctions records
    """
    try:
        conn = get_db_connection()
        cursor = conn.cursor()
        
        query = """
        SELECT [id], [name], [uniqid], [country], [source]
        FROM [dbo].[tf_sanctions]
        """
        
        log_message(f"Executing query: {query}", "SQL")
        cursor.execute(query)
        
        columns = [column[0] for column in cursor.description]
        results = []
        
        for row in cursor.fetchall():
            results.append(dict(zip(columns, row)))
        
        conn.close()
        log_message(f"Retrieved {len(results)} sanctions records", "SQL")
        
        return results
        
    except Exception as e:
        log_message(f"Failed to retrieve sanctions data: {str(e)}", "ERROR")
        raise


def add_sanction_entry(name, country, source,user_id=None):
    """
    Add a new entry to tf_sanctions table
    
    Args:
        name: Name to add
        country: Country information
        source: Source of the sanction
        
    Returns:
        tuple: (success: bool, message: str)
    """
    try:
        conn = get_db_connection()
        cursor = conn.cursor()
        
        # Generate unique ID
        import uuid
        uniqid = str(uuid.uuid4())
        
        query = """
        INSERT INTO [dbo].[tf_sanctions] ([UserID],[name], [uniqid], [country], [source])
        VALUES (?, ?, ?, ?, ?)
        """
        
        log_message(f"Adding new sanction entry: {name}", "SQL")
        cursor.execute(query, (user_id,name, uniqid, country, source))
        conn.commit()
        conn.close()
        
        log_message(f"Successfully added sanction entry: {name}", "ACTIVITY")
        return True, f"✅ Successfully added: {name}"
        
    except Exception as e:
        error_msg = f"Failed to add sanction entry: {str(e)}"
        log_message(error_msg, "ERROR")
        return False, f"❌ {error_msg}"


def save_screening_activity(serial_number, lc_number, input_name, input_address, matches_data, total_matches, records_processed, duration_seconds=None,user_id=None):
    """
    Save screening activity to tf_sanctions_activity table
    
    Args:
        serial_number: Unique serial number for this screening
        lc_number: Letter of Credit number
        input_name: Input name searched
        input_address: Input address searched
        matches_data: JSON string of matching results
        total_matches: Number of matches found
        records_processed: Total records screened
        duration_seconds: Time taken for screening
        
    Returns:
        bool: Success status
    """
    try:
        conn = get_db_connection()
        cursor = conn.cursor()
        
        # Insert activity record (table should already exist from create_activity_table.sql)
        insert_query = """
            INSERT INTO [dbo].[tf_sanctions_activity] 
            (
                [UserID],
                [serial_number],
                [lc_number],
                [input_name],
                [input_address],
                [matches_data],
                [total_matches],
                [records_processed],
                [screening_duration_seconds],
                [screening_status],
                [created_at]
            )
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, 'Completed', GETDATE())
            """

        
        cursor.execute(insert_query, (
            user_id,
            serial_number, 
            lc_number if lc_number else None,
            input_name, 
            input_address if input_address else None,
            matches_data,
            total_matches,
            records_processed,
            duration_seconds
        ))
        conn.commit()
        conn.close()
        
        lc_info = f" | LC: {lc_number}" if lc_number else ""
        log_message(f"Saved screening activity: {serial_number}{lc_info} | Matches: {total_matches}", "ACTIVITY")
        return True
        
    except Exception as e:
        print("❌ SQL ERROR:", e)
        log_message(f"Failed to save screening activity: {str(e)}", "ERROR")
        return False


def retrieve_screening_activity(serial_number):
    """
    Retrieve screening activity by serial number
    
    Args:
        serial_number: Serial number to retrieve
        
    Returns:
        dict: Activity record or None
    """
    try:
        conn = get_db_connection()
        cursor = conn.cursor()
        
        query = """
        SELECT [serial_number], [input_name], [input_address], [matches_data], [created_at]
        FROM [dbo].[tf_sanctions_activity]
        WHERE [serial_number] = ?
        """
        
        cursor.execute(query, (serial_number,))
        row = cursor.fetchone()
        
        if row:
            columns = [column[0] for column in cursor.description]
            result = dict(zip(columns, row))
            conn.close()
            log_message(f"Retrieved screening activity: {serial_number}", "ACTIVITY")
            return result
        
        conn.close()
        return None
        
    except Exception as e:
        log_message(f"Failed to retrieve screening activity: {str(e)}", "ERROR")
        return None

