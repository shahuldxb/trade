{
  "files": [],
  "include": ["client/src/**/*", "shared/**/*", "server/**/*", "client/src/pages/FrameworkFiles/Localization.tsx"],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts"],
   "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ]
  ,
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "strict": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["client/src/*"],
      "@components/*": ["client/src/components/*"],
      "@providers/*": ["client/src/providers/*"],
      "@layouts/*": ["client/src/layouts/*"],
      "@auth/*": ["client/src/auth/*"],
      "@utils/*": ["client/src/utils/*"],
      "@config/*": ["client/src/config/*"],
      "@routing/*": ["client/src/routing/*"],
      "@i18n/*": ["client/src/i18n/*"]
}

  }
}